generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  clerkId   String  @unique
  firstName String?
  lastName  String?
  role      String?

  teknisi Teknisi?

  createdAt DateTime @default(now())
}

model Teknisi {
  id     Int    @id @default(autoincrement())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  ipm Ipm[]

  createdAt DateTime @default(now())
}

model Ruangan {
  id          Int    @id @default(autoincrement())
  namaRuangan String

  alat Alat[]
  ipm  Ipm[]

  createdAt DateTime @default(now())
}

model Alat {
  id         Int       @id @default(autoincrement())
  nama       String
  merek      String
  tipe       String
  noSeri     String
  tahun      Int
  kalibrasi  DateTime?
  keterangan String?

  ruanganId Int
  ruangan   Ruangan @relation(fields: [ruanganId], references: [id])

  ipm Ipm[]

  createdAt DateTime @default(now())
}

model Ipm {
  id          Int      @id @default(autoincrement())
  hasil       String
  settingAlat String?
  terukur     String?
  createdAt   DateTime @default(now())

  alatId Int
  alat   Alat @relation(fields: [alatId], references: [id])

  ruanganId Int?
  ruangan   Ruangan? @relation(fields: [ruanganId], references: [id])

  teknisi Teknisi[]
}
